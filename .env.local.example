# Copie este arquivo para ".env.local" e preencha com as credenciais do seu projeto Supabase
# (Project Settings > API no painel do Supabase).

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-public

# API Key (v3 auth) da TMDB (themoviedb.org/settings/api) — usada só no
# servidor para buscar "onde assistir" cada filme no Brasil. Sem cartão,
# gratuita. NÃO leva o prefixo NEXT_PUBLIC_: fica só no servidor.
TMDB_API_KEY=sua-api-key-v3-da-tmdb
